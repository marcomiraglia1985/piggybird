generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id             String   @id @default(cuid())
  name           String   @unique
  type           String
  currency       String   @default("EUR")
  emoji          String?
  active         Boolean  @default(true)
  displayOrder   Int      @default(0)
  currentBalance Float    @default(0)
  ownershipShare Float    @default(1.0)
  closedAt       DateTime?

  /** Solo per conti savings: tasso annuo nominale lordo (cosmetico, mostrato
   *  affianco agli interessi reali — gli interessi netti veri si calcolano
   *  dalle tx con cat=Interessi). Es: 1.50 = 1.50%/anno. */
  interestRateAnnual Float?
  /** Note libere (banca, IBAN, vincolo, ecc.) */
  notes              String?
  /** Provider esterno (per gating delle integrazioni API in Impostazioni):
   *  "generic" = nessun API attivo (default — banca tradizionale, contante)
   *  "binance" = conto Binance, mostra setup API in Impostazioni
   *  "revolut-x" = conto Revolut X, mostra setup API
   *  Futuri: "n26", "fineco-psd2", "trade-republic", ecc. */
  provider           String   @default("generic")
  /** JSON-encoded array di membri per i conti type="friendsplit".
   *  Formato: '[{"name":"Mario Rossi"}, {"name":"Luca Bianchi"}]'
   *  Il primo membro è convenzionalmente l'utente proprietario dell'app.
   *  Null per conti non-friendsplit. */
  membersJson        String?

  transactions   Transaction[]
  balances       AccountBalance[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AccountBalance {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date      DateTime
  balance   Float

  @@unique([accountId, date])
  @@index([accountId])
}

model Category {
  id           String   @id @default(cuid())
  emoji        String
  name         String
  group        String
  type         String
  color        String?
  active       Boolean  @default(true)
  displayOrder Int      @default(0)

  /** Se settato, le tx in questa categoria si riferiscono SEMPRE all'immobile
   *  indicato (auto-link). Una categoria può appartenere a un solo immobile. */
  estateId     String?
  estate       RealEstate? @relation(fields: [estateId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  // Unique per (emoji, name) entro lo stesso scope: estate-specific se
  // estateId è valorizzato, generico se null. Due cat con stesso nome
  // possono coesistere se appartengono a immobili diversi (o una è
  // generica e l'altra estate-specific). Nota: SQLite tratta NULL come
  // distinct in unique multi-column, quindi il caso (emoji, name, null)
  // duplicato è bloccato dalla validazione manuale in /api/categories.
  @@unique([emoji, name, estateId])
  @@index([estateId])
}

model Transaction {
  id              String    @id @default(cuid())
  date            DateTime
  amount          Float
  accountId       String
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  beneficiary     String?
  notes           String?
  isJoint         Boolean   @default(false)
  year            Int
  month           Int

  /** Coppia transfer interno tra conti: due transazioni con stesso transferGroupId
   *  formano un trasferimento (importi opposti, conti diversi). */
  transferGroupId String?

  /** Tutte le occorrenze di un movimento ricorrente condividono lo stesso
   *  recurrenceGroupId. Permette delete/edit di gruppo. */
  recurrenceGroupId String?

  /** false = movimento programmato non ancora avvenuto (es. stipendio futuro
   *  da confermare). Quando l'utente lo "spunta", confirmed→true e date→oggi. */
  confirmed       Boolean   @default(true)
  /** Timestamp di quando confirmed è diventato true. Usato dal filtro display
   *  saldo per discriminare tx già nel snapshot vs aggiunte/confermate dopo
   *  il freeze. null se confirmed=false. Settata in POST/PATCH transactions. */
  confirmedAt     DateTime?

  /** Collegamento opzionale a un immobile (RealEstate). Permette di
   *  visualizzare entrate (affitto) e uscite (utenze, tasse, manutenzione)
   *  per ogni unità immobiliare. */
  estateId        String?
  estate          RealEstate? @relation(fields: [estateId], references: [id], onDelete: SetNull)

  /** Snapshot della quota di proprietà dell'account al momento del cambio
   *  delle regole di quota. Permette di applicare la NUOVA quota solo ai
   *  movimenti futuri, mantenendo la quota OLD sui movimenti storici.
   *  Null = nessuno snapshot, usa Account.ownershipShare correntemente. */
  ownershipShare  Float?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([date])
  @@index([year, month])
  @@index([accountId])
  @@index([transferGroupId])
  @@index([categoryId])
  @@index([confirmed])
  @@index([recurrenceGroupId])
  @@index([isJoint])
  @@index([estateId])
}

model NetWorthSnapshot {
  id          String   @id @default(cuid())
  month       DateTime @unique
  total       Float
  liquidity   Float?
  savings     Float?
  credits     Float?
  investments Float?
  notes       String?
  source      String   @default("manual")
}

model Investment {
  id           String   @id @default(cuid())
  name         String   @unique
  type         String
  platform     String
  currentValue Float
  /** Costo totale (entry price) — se noto. Permette di calcolare gain a livello
   *  di portafoglio anche quando il breakdown per asset non è disponibile. */
  costEur      Float?
  currency     String   @default("EUR")
  displayOrder Int      @default(0)
  lastUpdated  DateTime @default(now())
  notes        String?
}

/** Posizioni di trading (stocks, ETF, metalli). Prezzi live da Yahoo. */
model StockPosition {
  id            String   @id @default(cuid())
  ticker        String
  name          String?
  shares        Float
  /** Prezzo medio di carico (opzionale) */
  avgCost       Float?
  currentPrice  Float
  currency      String   @default("USD")
  /** Cambio applicato per ottenere il valore in EUR */
  fxToEur       Float    @default(1.0)
  platform      String   @default("Revolut")
  /** "stock" | "etf" | "metal" */
  assetType     String   @default("stock")
  isin          String?
  exchange      String?
  notes         String?
  lastUpdated   DateTime @default(now())

  @@unique([platform, ticker])
  @@index([platform])
}

/** Saldo cash dentro al conto trading (non in Revolut corrente).
 *  Tipicamente proventi di vendite ancora non re-investite. */
model TradingCash {
  id          String   @id @default(cuid())
  platform    String   @default("Revolut")
  currency    String
  amount      Float    @default(0)
  fxToEur     Float    @default(1.0)
  lastUpdated DateTime @default(now())

  @@unique([platform, currency])
}

/** P/L realizzati su posizioni chiuse (per chart performance). */
model RealizedPnL {
  id            String   @id @default(cuid())
  ticker        String
  name          String?
  isin          String?
  dateAcquired  DateTime
  dateSold      DateTime
  quantity      Float
  costBasis     Float
  proceeds      Float
  pnl           Float
  currency      String   @default("USD")
  fxAtSell      Float    @default(1.0)
  platform      String   @default("Revolut")
  assetType     String   @default("stock")

  @@index([platform, dateSold])
  @@index([ticker])
}

/** Eventi del trading account importati da CSV broker.
 *  Tipi:
 *   - "BUY" / "SELL": trade su asset (ticker richiesto)
 *   - "TOP-UP" / "WITHDRAWAL": cashflow in/out dell'account
 *   - "DIVIDEND" / "DIVIDEND_TAX": dividendi e relative tasse
 *   - "STOCK_SPLIT": split (ticker + quantity = nuove shares)
 *  amountEur è sempre la magnitudine assoluta in EUR (segno determinato dal type).
 *  Hash deduplica re-import dello stesso CSV.
 */
model StockTrade {
  id           String   @id @default(cuid())
  platform     String   // "Revolut", "Fineco", ...
  type         String
  date         DateTime
  ticker       String?
  quantity     Float?
  pricePerUnit Float?
  amountEur    Float    @default(0)
  currency     String   @default("EUR")
  fxRate       Float    @default(1.0)
  /** "revolut-csv-import" | "manual" | ... */
  source       String   @default("manual")
  hash         String   @unique

  @@index([platform, date])
  @@index([type, date])
  @@index([ticker])
}

/** Posizioni crypto sincronizzate da Binance (e in futuro altri exchange). */
model CryptoPosition {
  id          String   @id @default(cuid())
  asset       String
  amount      Float
  eurValue    Float
  source      String
  platform    String   @default("Binance")
  pricedVia   String?
  lastUpdated DateTime @default(now())

  @@unique([platform, source, asset])
  @@index([platform])
}

/** Trade crypto: ogni BUY/SELL fatto manualmente o da CSV import.
 *  Necessario per chart con marker (BUY/SELL) e cost basis FIFO. */
model CryptoTrade {
  id              String   @id @default(cuid())
  platform        String
  asset           String
  direction       String   // "buy" | "sell"
  quantity        Float
  pricePerUnit    Float
  /** prezzo per unit convertito in EUR al FX del giorno del trade */
  pricePerUnitEur Float
  currency        String   @default("EUR")
  totalEur        Float
  date            DateTime
  /** "manual" | "binance-csv" | "revolut-x-csv" | "form" */
  source          String   @default("manual")
  notes           String?
  /** opz: collegamento alla Transaction generata (transfer pair). */
  txId            String?
  createdAt       DateTime @default(now())

  @@index([platform, asset])
  @@index([date])
}

/** Cost basis manuale per asset crypto: tot EUR speso per le posizioni
 *  ATTUALMENTE detenute (al netto di vendite). Aggregato per (platform, asset).
 *  Permette di calcolare unrealized P/L anche quando non abbiamo dati di
 *  prezzo storici (es. acquisti antecedenti all'uso di Binance/Revolut X). */
model CryptoCostBasis {
  id        String   @id @default(cuid())
  platform  String
  asset     String
  costEur   Float
  notes     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([platform, asset])
  @@index([platform])
}

model Setting {
  key   String @id
  value String
}

/** Cache persistente del chart history /investimenti.
 *  Calcolare la history (replay daily + fetch Yahoo + Binance prices) costa
 *  5-10s. Cache invalidata via signature hash dei dati input: stesso hash
 *  → cache hit, nessun fetch. Hash cambia se cambia anche solo un trade,
 *  position, costEur, currentValue → cache miss → ricalcolo + save. */
model InvestmentsHistoryCache {
  id          String   @id @default("current")
  /** sha256 hash di JSON.stringify ordinato di tutti i dati di input
   *  (stock positions/trades, crypto positions/trades/costBases, investments).
   *  Stesso hash → safe to use cached history. */
  signature   String
  /** JSON.stringify dell'array HistoryPoint[] */
  history     String
  /** Quanti ms ha richiesto il calcolo (telemetry per monitorare slowness) */
  computeMs   Int?
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** Cache di parser CSV/XLSX riconosciuti via AI fallback.
 *  Quando un utente importa un file di banca non supportata dai parser
 *  deterministici, la app invia le prime righe a Claude (con la dev API
 *  key, in beta) per inferire un mapping {date col, amount col, ...}.
 *  Il mapping viene salvato qui, indicizzato per `signature` (hash dei
 *  primi N header) — al prossimo upload con stessa signature, hit cache:
 *  niente nuova chiamata AI. */
model ParserTemplate {
  /** sha256 dei primi N header (lowercase, sorted) */
  signature   String   @id
  /** "bank" (default) per CSV banche → ParsedRow, "broker" per CSV broker
   *  → StockEvent. Determina lo schema atteso del mapping JSON. */
  kind        String   @default("bank")
  /** Nome banca/broker inferito dall'AI (es. "N26", "eToro") — solo display */
  bankName    String?
  /** Mapping JSON: { dateCol: 0, amountCol: 3, descCol: 5, skipRows: 0,
   *  amountSign: "signed" | "split", entrateCol?: ..., usciteCol?: ...,
   *  dateFormat: "dd/mm/yyyy" | "iso" | "excel-serial" | ...,
   *  decimalSep: "," | ".", currency: "EUR", ...} */
  mapping     String
  /** Headers originali (per debug e display) */
  sampleHeaders String?
  /** Telemetria: quante volte questo template è stato applicato */
  usageCount  Int      @default(0)
  /** Costo in EUR della chiamata AI iniziale */
  aiCostEur   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** Filtri salvati per /movimenti (combo year+account+cat+q etc). */
model SavedFilter {
  id           String   @id @default(cuid())
  name         String
  emoji        String?
  /** JSON URL search params (es. {"year":"2026","account":"abc","cat":"xyz","q":"affitto"}) */
  query        String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/** Crediti: cauzioni/caparre, prestiti fatti, soldi che mi devono tornare.
 *  NON contano nel net worth (sono "soldi volanti" già usciti, da reincassare). */
model Credit {
  id             String    @id @default(cuid())
  name           String
  /** Chi ha i soldi (es. "Proprietario casa Malaga", "Fabio") */
  counterparty   String?
  amount         Float
  currency       String    @default("EUR")
  /** Quando è uscito il denaro */
  date           DateTime?
  /** Data attesa di restituzione (opzionale) */
  expectedReturn DateTime?
  /** "active" = ancora da restituire | "returned" | "lost" */
  status         String    @default("active")
  emoji          String?
  notes          String?
  displayOrder   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
}

/** Immobili: ogni unità con i suoi dati di acquisto/affitto. Le entrate
 *  (affitto) e le uscite (utenze, tasse, manutenzione) si collegano via
 *  Transaction.estateId. NON contano direttamente nel net worth — il valore
 *  immobiliare è tracciato a parte (currentValue). */
model RealEstate {
  id             String   @id @default(cuid())
  name           String
  /** "apartment" | "house" | "commercial" | "land" | "other" */
  type           String   @default("apartment")
  emoji          String   @default("🏠")
  /** "owned" = di proprietà | "rented" = sono inquilino (affitto pagato) */
  holding        String   @default("owned")
  address        String?
  city           String?
  country        String?
  /** Data di acquisto (solo per immobili di proprietà) */
  purchaseDate   DateTime?
  /** Prezzo di acquisto (solo per immobili di proprietà) */
  purchasePrice  Float?
  /** Valore stimato attuale (solo per immobili di proprietà). Se null si
   *  usa `purchasePrice` come fallback con un alert "stimato". */
  currentValue   Float?
  /** Data dell'ultimo aggiornamento di `currentValue`. Quando >5 anni fa
   *  o null si mostra alert "valore obsoleto, da riconfermare". */
  currentValueUpdatedAt DateTime?
  /** Quota di proprietà (0..1). 1.0 = pieno possesso. Ignorato se holding="rented". */
  ownershipShare Float    @default(1.0)
  /** Affitto mensile in valore assoluto (€). Per holding="owned" è quanto
   *  incassi (positive cashflow), per holding="rented" è quanto paghi
   *  (negative cashflow). Null se non c'è componente rent. */
  monthlyRent    Float?
  currency       String   @default("EUR")
  notes          String?
  active         Boolean  @default(true)
  displayOrder   Int      @default(0)

  /** Mutuo (opzionale, solo per holding="owned"). Se mortgageAmount è
   *  presente al create, viene auto-generata: (1) la categoria "🏦 Mutuo {name}"
   *  linkata all'estate (type=expense), (2) 12 tx ricorrenti confirmed=false
   *  sull'account scelto dall'utente, condividendo `mortgageRecurrenceGroupId`. */
  mortgageAmount         Float?
  /** Tasso annuo nominale in % (es. 3.5 = 3.5% annuo). Convertito a tasso
   *  mensile per la formula francese: i_mensile = ratePct/100/12. */
  mortgageRate           Float?
  mortgageDurationMonths Int?
  mortgageStartDate      DateTime?
  /** Rata mensile calcolata server-side via formula francese. Salvata per
   *  evitare drift di calcolo client/server e per visualizzazione diretta. */
  mortgageMonthlyPayment Float?
  /** recurrenceGroupId delle tx mutuo auto-generate. Permette al detail page
   *  di linkare direttamente alla pagina ricorrenze per
   *  estensione/modifica/cancellazione. */
  mortgageRecurrenceGroupId String?

  transactions   Transaction[]
  categories     Category[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/** Credenziali API esterne (Binance, banche…). Tutto cifrato AES-256-GCM
 *  con APP_MASTER_KEY dal .env. Mai esposte al client. */
model ApiCredential {
  provider    String   @id
  apiKey      String   // base64 ciphertext
  /** Alcuni provider hanno una sola chiave (es. Anthropic) → opzionale.
   *  Se presente, è il secret cifrato (es. Binance) o key extra. */
  apiSecret   String?
  iv          String   // base64
  authTag     String   // base64
  /** Metadata pubblici (es. ultime 4 cifre key per UI) */
  hint        String?
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** Tracking di ogni chiamata AI (Claude API) per uso/costo monitoring.
 *  Inserito solo dopo una chiamata user-triggered → niente background. */
model AIUsage {
  id           String   @id @default(cuid())
  feature      String   // es. "auto-categorize", "test-credential", ...
  model        String   // es. "claude-sonnet-4-6"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  /** Costo in EUR (calcolato lato client/server da prezzi Anthropic). */
  costEur      Float    @default(0)
  /** Esito: "ok" | "error" | "rate_limited" */
  status       String   @default("ok")
  errorMsg     String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([feature, createdAt])
}
